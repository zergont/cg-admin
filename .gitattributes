# Принудительно LF для всех текстовых файлов проекта
* text=auto eol=lf

*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
*.txt       text eol=lf

# Бинарные файлы — без конвертации
*.db        binary
*.sqlite    binary
*.png       binary
*.ico       binary
