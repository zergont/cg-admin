# ============================================================
# CG Admin Panel — config.yaml
# Версия конфига: 1.0.0
# ============================================================
# Скопируйте в config.yaml и заполните значения.
# Путь задаётся через переменную CG_ADMIN_CONFIG.

app:
  name: "CG Admin"
  debug: false
  # Версия приложения задаётся не здесь, а в файле VERSION в корне репозитория —
  # его читают backend (__version__) и frontend (sync-version.mjs).

auth:
  # Bearer token для cg-admin (независим от токена UI Dashboard)
  token: "4879d3f5f6a03baf3fd3794c32ee3f5ca6fc6b3542f737e9"
  lan_subnets:
    - "127.0.0.0/8"
    - "192.168.0.0/16"
    - "172.16.0.0/12"

database:
  # Read-only подключение к PostgreSQL (для метрик, Этап 2)
  postgres_host: "localhost"
  postgres_port: 5432
  postgres_dbname: "cg_telemetry"
  postgres_user: "cg_ui"
  postgres_password: "cg_ui"

  # Локальная SQLite для audit/update логов
  sqlite_path: "/opt/cg-admin/data/admin.db"

services:
  # Allowlist systemd юнитов — только эти можно рестартить через API
  allowed_units:
    - cg-dashboard
    - cg-decoder
    - cg-db-writer
    - mosquitto
    - nginx
    - chrony

  # Список служб для мониторинга на Overview
  # Можно переопределить дефолтный список
  monitored_units:
    - name: "UI Dashboard"
      unit: "cg-dashboard"
      url: "https://192.168.0.130:9443"
    - name: "Modbus-декодер"
      unit: "cg-decoder"
      url: "http://192.168.0.130:8080"
    - name: "DB-Writer"
      unit: "cg-db-writer"
    - name: "MQTT Server"
      unit: "mosquitto"
    - name: "PostgreSQL"
      unit: "postgresql"
    - name: "Wireguard VPN"
      unit: "wg-quick@MQTT"
    - name: "WGDashboard"
      unit: "wg-dashboard"
      url: "http://192.168.0.130:10086"
    - name: "Nginx"
      unit: "nginx"
    - name: "Chrony (NTP)"
      unit: "chrony"
    - name: "Admin Panel"
      unit: "cg-admin"
      url: "https://192.168.0.130:9443/admin/"

diagnostics:
  # DB-Writer health endpoint
  db_writer_health_url: "http://127.0.0.1:8765/health"
  # MQTT-брокер
  mqtt_host: "localhost"
  mqtt_port: 1883
  mqtt_smoke_timeout_sec: 3.0
  # Данные в latest_state протухли если старше N секунд
  latest_state_stale_sec: 300
  # telemetry2 (декодер) stats endpoint
  decoder_health_url: "http://127.0.0.1:8080/api/stats"
  # UI Dashboard health endpoint (оставьте пустым чтобы пропустить проверку)
  dashboard_health_url: "http://127.0.0.1:5555/api/health"
  # Имя интерфейса WireGuard для проверки состояния туннеля (`sudo wg show`)
  wg_interface: "wg0"
  # Рукопожатие с пиром считается протухшим (warn), если старше N секунд
  wg_handshake_stale_sec: 180
  # Рукопожатие считается "залипшим" (crit) — клиент сменил IP и не может
  # переподключиться, само не восстановится — если старше N секунд
  wg_handshake_dead_sec: 3600

modules:
  - name: "UI Dashboard"
    repo: "https://github.com/zergont/UI-telemetry"
    repo_path: "/opt/cg-dashboard"
    service: "cg-dashboard"
    branch: "master"
    has_frontend: true
    has_backend: true

  - name: "Modbus-декодер"
    repo: "https://github.com/zergont/telemetry2"
    repo_path: "/opt/cg-decoder"
    service: "cg-decoder"
    branch: "master"
    has_frontend: false
    has_backend: true
    # Директории и файлы с пользовательскими данными — после деплоя их
    # владелец восстанавливается на пользователя сервиса (по умолчанию ["maps"]).
    # Веб-морда декодера пишет в maps/, devices/ и config.yaml
    data_dirs: ["maps", "devices", "config.yaml"]

  - name: "DB-Writer"
    repo: "https://github.com/zergont/DB_MQTT"
    repo_path: "/home/folist/db-writer"
    service: "cg-db-writer"
    branch: "master"
    has_frontend: false
    has_backend: true

  - name: "MQTT Server"
    repo: "https://github.com/zergont/MQTT_Server"
    repo_path: "/opt/cg-mqtt-broker"
    service: "mosquitto"
    branch: "master"
    has_frontend: false
    has_backend: false

  - name: "Admin Panel"
    repo: "https://github.com/zergont/cg-admin"
    repo_path: "/opt/cg-admin"
    service: "cg-admin"
    branch: "main"
    has_frontend: true
    has_backend: true
    self: true  # Самообновление через POST /admin/api/system/update (запускает cg-deploy@cg-admin.service)
